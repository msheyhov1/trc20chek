# Эти переменные нужно задать в Railway → Variables (НЕ заливать в git)

# --- Обязательно ---
BOT_TOKEN=

# --- Опционально (повышают лимиты, бесплатные) ---
TRONSCAN_API_KEY=
GOPLUS_API_KEY=

# --- Опциональная защита публичного API ---
# Если задано — внешние запросы должны слать ?api_key=...
API_KEY=

# --- Кеш ---
CACHE_TTL_SECONDS=604800
# CACHE_PATH задаётся автоматически на /data/cache.db
