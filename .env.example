# Эти переменные нужно задать в Railway → Variables (НЕ заливать в git)

# --- Обязательно ---
BOT_TOKEN=

# --- Опционально (повышают лимиты, бесплатные) ---
TRONSCAN_API_KEY=
GOPLUS_API_KEY=

# --- Опциональная защита публичного API ---
# Если задано — внешние запросы должны слать ?api_key=...
API_KEY=

# --- Пароль на веб-сайт (HTTP Basic Auth) ---
# Если задан WEB_PASSWORD — сайт (/ и /check) спросит логин/пароль.
# Пусто = сайт открыт. Логин по умолчанию admin, можно сменить через WEB_USER.
WEB_USER=admin
WEB_PASSWORD=

# --- Доступ к боту по Telegram ID ---
# Список разрешённых Telegram user_id через запятую/пробел.
# Пусто = бот ОТКРЫТ всем. Свой ID можно узнать: напишите боту — он вернёт его в отказе,
# либо спросите у @userinfobot.
ALLOWED_TG_IDS=

# --- Внешний AML: Swapster (туннель) ---
# Запрашивается ТОЛЬКО для НЕ-биржевых кошельков (биржи/депозитники/контракты
# AML не проверяются). Пусто → в выводе «Swapster не настроен».
SWAPSTER_API_TOKEN=
# Боевой: https://api.swapster.fi · тест: https://test-api.swapster.fi
SWAPSTER_API_BASE_URL=https://api.swapster.fi
# Опц. прокси со статичным IP под whitelist Swapster (http://user:pass@host:port или socks5://host:port)
SWAPSTER_PROXY_URL=
SWAPSTER_PAY_CURRENCY=USDT
SWAPSTER_CHECK_CURRENCY=USDT
SWAPSTER_CHECK_NETWORK=TRC20
SWAPSTER_TIMEOUT_SECONDS=30

# --- Кеш ---
CACHE_TTL_SECONDS=604800
# CACHE_PATH задаётся автоматически на /data/cache.db
